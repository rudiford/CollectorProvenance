{
  "name": "collector-car-registry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"server,client\" --prefix-colors \"cyan,green\" \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client && npm run build --workspace=server",
    "start": "NODE_ENV=production node server/dist/index.js"
  },
  "workspaces": ["client", "server"],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
